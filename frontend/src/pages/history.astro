---
import Layout from "@/layouts/Layout.astro"

const ROOM_ID = "sitcon-camp-2026"
const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL

type RoundRecord = {
  gameNumber?: number
  round: number
  matchup: { groupA: number; groupB: number }
  topic: string
  answerA: string
  answerB: string
  scoreA: number
  scoreB: number
  winner: "A" | "B" | "tie"
  reason: string
}
---

<Layout>
  <div id="match-root"></div>
</Layout>

<script>
  const ROOM_ID = "sitcon-camp-2026"
  const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL

  const root = document.getElementById("match-root")

  let state = {
    statusText: "載入中...",
    modeText: "載入中",
    groupedMatches: [],
    loadFailed: false,
  }

  async function fetchWithTimeout(url, timeout = 5000) {
    const controller = new AbortController()
    const t = setTimeout(() => controller.abort(), timeout)

    try {
      return await fetch(url, { signal: controller.signal })
    } finally {
      clearTimeout(t)
    }
  }

  function groupRounds(rounds) {
    const map = new Map()

    for (const round of rounds) {
      const key = round.gameNumber
        ? `game-${round.gameNumber}`
        : `${round.matchup.groupA}-${round.matchup.groupB}`

      if (!map.has(key)) {
        map.set(key, {
          key,
          matchup: round.matchup,
          rounds: [],
        })
      }

      map.get(key).rounds.push(round)
    }

    return [...map.values()]
  }

  async function load() {
    try {
      const res = await fetchWithTimeout(`${BACKEND_URL}/rooms/${ROOM_ID}`)

      if (res.status === 404) {
        state.statusText = "目前還沒有任何對戰紀錄"
        state.modeText = "尚無紀錄"
        render()
        return
      }

      if (!res.ok) throw new Error("fetch failed")

      const data = await res.json()

      const rounds = Array.isArray(data.rounds) ? data.rounds : []

      state.groupedMatches = groupRounds(rounds)

      state.modeText = data.matchMode === "test" ? "測試場" : "正式場"

      state.statusText =
        rounds.length === 0 ? "目前還沒有任何對戰紀錄" : `共 ${rounds.length} 回合資料`
    } catch (e) {
      state.loadFailed = true
      state.statusText = "目前無法載入對戰紀錄"
      state.modeText = "載入失敗"
    }

    render()
  }

  function render() {
    root.innerHTML = `
      <div class="card bg-base-300 w-full">
        <div class="card-body">
          <h1 class="text-2xl font-bold">對戰紀錄</h1>
          <p class="text-sm opacity-60">${state.statusText}</p>
          <span class="badge">${state.modeText}</span>
        </div>
      </div>

      <div class="mt-4">
        ${
          state.groupedMatches.length === 0
            ? `<div class="p-4 opacity-60">目前沒有資料</div>`
            : state.groupedMatches.map(
                (m) => `
              <div class="border p-4 rounded-xl mt-3">
                <div class="font-bold">
                  ${m.matchup.groupA} vs ${m.matchup.groupB}
                </div>

                <div class="text-sm opacity-60">
                  ${m.rounds.length} 回合
                </div>

                <div class="mt-3 space-y-2">
                  ${m.rounds
                    .map(
                      (r) => `
                    <div class="border rounded p-2 text-sm">
                      <div>第 ${r.round} 回合</div>
                      <div>題目：${r.topic || "無"}</div>

                      <div class="mt-1">
                        A：${r.answerA || "未作答"} (${r.scoreA})
                      </div>

                      <div>
                        B：${r.answerB || "未作答"} (${r.scoreB})
                      </div>

                      <div class="mt-1">
                        勝者：${r.winner}
                      </div>

                      <div class="opacity-70 mt-1">
                        ${r.reason || "無說明"}
                      </div>
                    </div>
                  `
                    )
                    .join("")}
                </div>
              </div>
            `
              )
        }
      </div>
    `
  }

  window.addEventListener("DOMContentLoaded", () => {
    load()
  })
</script>
